﻿@using StockMePhotos.ViewModels.Photo;
@model IEnumerable<PhotoViewModel>;

<div class="photos-container">
    <div class="photos-list">
        @foreach (PhotoViewModel photo in Model)
        {
            <div class="photo-card">
                <div class="photo-title">@photo.Title</div>
                <div class="photo-src">
                    <a asp-controller="Photo" asp-action="Details" asp-route-id="@photo.Id">
                        <img src="@photo.ImageURL" />
                    </a>
                </div>
                <div class="photo-categories">
                    @foreach (string category in photo.Categories)
                    {
                        <span>@category</span>
                    }
                </div>
            </div>
        }
    </div>

</div>