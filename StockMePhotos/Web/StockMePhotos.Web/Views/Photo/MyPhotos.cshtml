@using StockMePhotos.ViewModels.Category
@model MyPhotosListViewModel

@{
    ViewData["PageTitle"] = "My Photos";
}

<div class="page-content">
    <h1 class="page-title">@ViewData["PageTitle"]</h1>

    <div class="my-photo-list">
        @if (Model.AllPhotos.Count() == 0)
        {
            <h2>No photos yet to show.</h2>
        }
        else
        {
            @foreach (PhotoViewModel photo in Model.AllPhotos)
            {
                <div class="photo-v-card">
                    <div class="photo-res">
                        <img src="@photo.ImageURL" />
                    </div>
                    <div class="photo-info">
                        <h3>@photo.Title</h3>
                        <p>Date Added: @photo.DateAdded</p>
                        <div class="categories">
                            @foreach (string cat in photo.Categories)
                            {
                                <span class="s-cat">@cat</span>
                            }
                        </div>
                        <div class="actions">
                            <a class="btn btn-primary" asp-controller="Photo" asp-action="Details" asp-route-id="@photo.Id">Details</a>
                            <a class="btn btn-warning" asp-controller="Photo" asp-action="Edit" asp-route-id="@photo.Id">Edit</a>
                            <form asp-controller="Photo" asp-action="Delete" asp-route-id="@photo.Id" method="post">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>