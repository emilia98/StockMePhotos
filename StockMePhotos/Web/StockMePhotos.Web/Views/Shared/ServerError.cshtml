@{
    ViewData["Title"] = "Error 500 - Server Error";
}

<div class="container d-flex align-items-center justify-content-center error-container">
    <div class="text-center">
        <div class="error-code text-danger">500</div>
        <h1 class="mb-3">Internal Server Error</h1>
        <p class="error-text text-muted mb-4">
            Something went wrong on our end. Please try again later.
        </p>
        <a href="@(Url.Action("Index", "Home"))" class="btn btn-primary btn-lg btn-custom">Go Home</a>
    </div>
</div>