@{
    ViewData["Title"] = "Error 404 - Not Found";
}

<div class="container d-flex align-items-center justify-content-center error-container">
    <div class="text-center">
        <div class="error-code text-danger">404</div>
        <h1 class="mb-3">Page Not Found</h1>
        <p class="error-text text-muted mb-4">
            Sorry, the page you are looking for doesn’t exist or has been moved.
        </p>
        <a href="@(Url.Action("Index", "Home"))" class="btn btn-primary btn-lg btn-custom">Go Home</a>
    </div>
</div>