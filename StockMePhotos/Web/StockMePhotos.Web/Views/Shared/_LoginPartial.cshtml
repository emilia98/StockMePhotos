@using Microsoft.AspNetCore.Identity
@using StockMePhotos.Data.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav cm-navbar">
@if (SignInManager.IsSignedIn(User))
{
        <li class="nav-item">
            <a class="btn btn-primary btn-custom" asp-controller="Photo" asp-action="Add">Add Photo</a>
        </li>
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                @UserManager.GetUserName(User)!
            </a>
            <ul class="dropdown-menu">
                <li>
                    <a id="manage" class="dropdown-item text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">My Profile</a>
                </li>
                <li>
                    <a class="dropdown-item text-dark" asp-controller="Photo" asp-action="MyPhotos" asp-route-username="@UserManager.GetUserName(User)!">My Photos</a>
                </li>
                <li>
                    <a class="dropdown-item text-dark" asp-controller="Photo" asp-action="Favorites" asp-route-username="@UserManager.GetUserName(User)!">Favorites</a>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>
                <li>
                    <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button id="logout" type="submit" class="dropdown-item btn btn-link text-danger border-0">Logout</button>
                    </form>
                </li>
            </ul>
        </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
