@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">
    <div class="text-center">
        <h1 class="display-4 mb-3 text-custom dashboard">Welcome to the Admin Dashboard</h1>
        <p class="lead mb-5 text-dark">Manage the application using the sections below:</p>
    </div>

    <div class="row g-4">

        <!-- Users -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-people-fill display-4 text-primary mb-3"></i>
                    <h5 class="card-title">Users</h5>
                    <p class="card-text">Manage user accounts, roles, and permissions.</p>
                    <a href="#" class="btn btn-primary">Manage Users</a>
                </div>
            </div>
        </div>

        <!-- Tags -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-tags-fill display-4 text-success mb-3"></i>
                    <h5 class="card-title">Tags</h5>
                    <p class="card-text">Create and organize tags for better content filtering.</p>
                    <a asp-area="Admin" asp-controller="Tag" asp-action="Index" class="btn btn-success">Manage Tags</a>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-folder-fill display-4 text-warning mb-3"></i>
                    <h5 class="card-title">Categories</h5>
                    <p class="card-text">Structure your content with categories and hierarchies.</p>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-warning text-white">Manage Categories</a>
                </div>
            </div>
        </div>

        <!-- Photos -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-image-fill display-4 text-danger mb-3"></i>
                    <h5 class="card-title">Photos</h5>
                    <p class="card-text">Upload, edit, and manage your image library.</p>
                    <a href="#" class="btn btn-danger">Manage Photos</a>
                </div>
            </div>
        </div>

    </div>
</div>